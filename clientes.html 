<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>SmartBiz | Clientes</title>

    <link rel="stylesheet" href="css/style.css">

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

</head>

<body>

<div class="dashboard">

    <!-- MENU -->

    <aside class="sidebar">

        <div class="logo">
            <i class="fa-solid fa-chart-line"></i>
            <h2>SmartBiz</h2>
        </div>

        <ul>

            <li>
                <a href="dashboard.html">
                    <i class="fa-solid fa-house"></i>
                    Dashboard
                </a>
            </li>

            <li>
                <a href="produtos.html">
                    <i class="fa-solid fa-box"></i>
                    Produtos
                </a>
            </li>

            <li class="active">
                <a href="clientes.html">
                    <i class="fa-solid fa-users"></i>
                    Clientes
                </a>
            </li>

            <li>
                <a href="estoque.html">
                    <i class="fa-solid fa-warehouse"></i>
                    Estoque
                </a>
            </li>

            <li>
                <a href="vendas.html">
                    <i class="fa-solid fa-cart-shopping"></i>
                    Vendas
                </a>
            </li>

            <li>
                <a href="financeiro.html">
                    <i class="fa-solid fa-wallet"></i>
                    Financeiro
                </a>
            </li>

        </ul>

    </aside>

    <!-- CONTEÚDO -->

    <main class="content">

        <header class="topbar">

            <h1>Clientes</h1>

            <button class="novo-produto">
                <i class="fa-solid fa-user-plus"></i>
                Novo Cliente
            </button>

        </header>

        <!-- PESQUISA -->

        <section class="pesquisa">

            <input
                type="text"
                placeholder="Pesquisar cliente...">

        </section>

        <!-- TABELA -->

        <section class="tabela">

            <table>

                <thead>

                    <tr>

                        <th>ID</th>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>E-mail</th>
                        <th>Cidade</th>
                        <th>Ações</th>

                    </tr>

                </thead>

                <tbody>

                    <tr>

                        <td>001</td>
                        <td>João Silva</td>
                        <td>(34) 99999-1111</td>
                        <td>joao@email.com</td>
                        <td>Patos de Minas</td>

                        <td>

                            <button class="editar">
                                <i class="fa-solid fa-pen"></i>
                            </button>

                            <button class="excluir">
                                <i class="fa-solid fa-trash"></i>
                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>002</td>
                        <td>Maria Souza</td>
                        <td>(34) 98888-2222</td>
                        <td>maria@email.com</td>
                        <td>Patos de Minas</td>

                        <td>

                            <button class="editar">
                                <i class="fa-solid fa-pen"></i>
                            </button>

                            <button class="excluir">
                                <i class="fa-solid fa-trash"></i>
                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>003</td>
                        <td>Carlos Oliveira</td>
                        <td>(34) 97777-3333</td>
                        <td>carlos@email.com</td>
                        <td>Patos de Minas</td>

                        <td>

                            <button class="editar">
                                <i class="fa-solid fa-pen"></i>
                            </button>

                            <button class="excluir">
                                <i class="fa-solid fa-trash"></i>
                            </button>

                        </td>

                    </tr>

                </tbody>

            </table>

        </section>

    </main>

</div>

<script src="js/script.js"></script>

</body>

</html>