// =========================================
// SMART BURGER - CARDÁPIO (CORRIGIDO)
// =========================================

// ELEMENTOS (SEGUROS)
const modal = document.getElementById("modalProduto");
const btnNovo = document.querySelector(".btn-primary");
const fecharModalBtn = document.querySelector(".fechar-modal");
const cancelar = document.querySelector(".cancelar");
const form = document.getElementById("formProduto");
const gridProdutos = document.querySelector(".produtos-grid");
const pesquisa = document.getElementById("pesquisaProduto");
const filtroCategoria = document.getElementById("categoria");

// PROTEÇÃO (EVITA TELA BRANCA)
if (btnNovo) {
    btnNovo.addEventListener("click", () => {
        modal.style.display = "flex";
    });
}

function fechar() {
    if (!modal) return;
    modal.style.display = "none";
    form?.reset();
}

if (fecharModalBtn) fecharModalBtn.addEventListener("click", fechar);
if (cancelar) cancelar.addEventListener("click", fechar);

window.addEventListener("click", (e) => {
    if (e.target === modal) fechar();
});

// LOCAL STORAGE
let produtos = JSON.parse(localStorage.getItem("produtos")) || [];

// IMAGEM PADRÃO
const IMAGEM_PADRAO =
"https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=600";

let imagemProduto = IMAGEM_PADRAO;

// IMAGEM UPLOAD
const inputImagem = document.getElementById("fotoProduto");

if (inputImagem) {
    inputImagem.addEventListener("change", (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (event) => {
            imagemProduto = event.target.result;
        };
        reader.readAsDataURL(file);
    });
}

// SALVAR
function salvarProdutos() {
    localStorage.setItem("produtos", JSON.stringify(produtos));
}

// CADASTRAR
if (form) {
    form.addEventListener("submit", function (e) {
        e.preventDefault();

        const produto = {
            id: Date.now(),
            nome: document.getElementById("nomeProduto").value,
            categoria: document.getElementById("categoriaProduto").value,
            descricao: document.getElementById("descricaoProduto").value,
            preco: Number(document.getElementById("precoProduto").value),
            custo: Number(document.getElementById("custoProduto").value),
            estoque: Number(document.getElementById("estoqueProduto").value),
            estoqueMinimo: Number(document.getElementById("estoqueMinimo").value),
            status: document.getElementById("statusProduto").value,
            imagem: imagemProduto
        };

        produtos.push(produto);
        salvarProdutos();
        renderizarProdutos();
        fechar();

        imagemProduto = IMAGEM_PADRAO;
    });
}

// RENDER
function renderizarProdutos() {
    if (!gridProdutos) return;

    gridProdutos.innerHTML = "";

    if (produtos.length === 0) {
        gridProdutos.innerHTML = `
        <div class="sem-produtos">
            <h2>Nenhum produto cadastrado</h2>
        </div>`;
        return;
    }

    produtos.forEach(produto => {
        const card = document.createElement("div");
        card.className = "produto-card";

        card.innerHTML = `
            <img src="${produto.imagem}" />

            <div class="produto-info">
                <h3>${produto.nome}</h3>
                <p>${produto.descricao}</p>

                <div class="preco">
                    R$ ${produto.preco.toFixed(2)}
                </div>

                <div class="acoes">
                    <button onclick="editarProduto(${produto.id})">Editar</button>
                    <button onclick="excluirProduto(${produto.id})">Excluir</button>
                </div>
            </div>
        `;

        gridProdutos.appendChild(card);
    });
}

// EXCLUIR
function excluirProduto(id) {
    produtos = produtos.filter(p => p.id !== id);
    salvarProdutos();
    renderizarProdutos();
}

// EDITAR
function editarProduto(id) {
    const produto = produtos.find(p => p.id === id);
    if (!produto) return;

    document.getElementById("nomeProduto").value = produto.nome;
    document.getElementById("categoriaProduto").value = produto.categoria;
    document.getElementById("descricaoProduto").value = produto.descricao;
    document.getElementById("precoProduto").value = produto.preco;
    document.getElementById("custoProduto").value = produto.custo;
    document.getElementById("estoqueProduto").value = produto.estoque;
    document.getElementById("estoqueMinimo").value = produto.estoqueMinimo;
    document.getElementById("statusProduto").value = produto.status;

    produtos = produtos.filter(p => p.id !== id);

    modal.style.display = "flex";
}

// INICIAL
document.addEventListener("DOMContentLoaded", renderizarProdutos);