<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>SmartBiz | Dashboard</title>

    <link rel="stylesheet" href="css/style.css">

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

</head>

<body>

    <div class="dashboard">

        <!-- MENU LATERAL -->

        <aside class="sidebar">

            <div class="logo">

                <i class="fa-solid fa-chart-line"></i>

                <h2>SmartBiz</h2>

            </div>

            <ul>

                <li class="active">
                    <a href="dashboard.html">
                        <i class="fa-solid fa-house"></i>
                        Dashboard
                    </a>
                </li>

                <li>
                    <a href="produtos.html">
                        <i class="fa-solid fa-box"></i>
                        Produtos
                    </a>
                </li>

                <li>
                    <a href="clientes.html">
                        <i class="fa-solid fa-users"></i>
                        Clientes
                    </a>
                </li>

                <li>
                    <a href="estoque.html">
                        <i class="fa-solid fa-warehouse"></i>
                        Estoque
                    </a>
                </li>

                <li>
                    <a href="vendas.html">
                        <i class="fa-solid fa-cart-shopping"></i>
                        Vendas
                    </a>
                </li>

                <li>
                    <a href="financeiro.html">
                        <i class="fa-solid fa-wallet"></i>
                        Financeiro
                    </a>
                </li>

            </ul>

        </aside>

        <!-- CONTEÚDO -->

        <main class="content">

            <!-- TOPO -->

            <header class="topbar">

                <h1>Dashboard</h1>

                <div class="usuario">

                    <i class="fa-solid fa-user-circle"></i>

                    <span>Administrador</span>

                </div>

            </header>

            <!-- CARDS -->

            <section class="cards">

                <div class="card">

                    <i class="fa-solid fa-money-bill-trend-up"></i>

                    <h3>Faturamento</h3>

                    <h2>R$ 12.580,00</h2>

                </div>

                <div class="card">

                    <i class="fa-solid fa-cart-shopping"></i>

                    <h3>Vendas</h3>

                    <h2>328</h2>

                </div>

                <div class="card">

                    <i class="fa-solid fa-users"></i>

                    <h3>Clientes</h3>

                    <h2>146</h2>

                </div>

                <div class="card">

                    <i class="fa-solid fa-box"></i>

                    <h3>Produtos</h3>

                    <h2>98</h2>

                </div>

            </section>

            <!-- TABELA -->

            <section class="tabela">

                <div class="titulo">

                    <h2>Últimas Vendas</h2>

                </div>

                <table>

                    <thead>

                        <tr>

                            <th>Cliente</th>

                            <th>Produto</th>

                            <th>Valor</th>

                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        <tr>

                            <td>João Silva</td>

                            <td>Notebook Dell</td>

                            <td>R$ 4.200,00</td>

                            <td><span class="status ok">Pago</span></td>

                        </tr>

                        <tr>

                            <td>Maria Souza</td>

                            <td>Mouse Gamer</td>

                            <td>R$ 180,00</td>

                            <td><span class="status ok">Pago</span></td>

                        </tr>

                        <tr>

                            <td>Carlos Lima</td>

                            <td>Teclado Mecânico</td>

                            <td>R$ 350,00</td>

                            <td><span class="status pendente">Pendente</span></td>

                        </tr>

                    </tbody>

                </table>

            </section>

        </main>

    </div>
    <div class="dashboard">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <!-- menu aqui -->
    </aside>

    <!-- CONTEÚDO -->
    <main class="content">

        <!-- TOPO PADRÃO -->
        <header class="topbar">
            <h1>Título da Página</h1>
            <button class="btn-primary">Ação</button>
        </header>

        <!-- CONTEÚDO -->
        <section>
            <!-- cards / tabela / formulário -->
        </section>

    </main>

</div>

    <script src="js/script.js"></script>

</body>

</html>